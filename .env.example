# =============================================================================
# TOIA — environment configuration
# Copy this file to `.env` and fill in the values, then `docker compose up`.
#
# After the cleanup, the ONLY required external account is OpenAI.
# Everything else has sensible local defaults that work with docker-compose.
# =============================================================================

# --- Phoenix / app ----------------------------------------------------------
# Public base URL of the API service. Used to build media playback URLs and
# (optionally) email links. For local docker-compose this is localhost:4000.
API_URL=http://localhost:4000

# Secret used by Guardian to sign auth (JWT) tokens.
# Generate one with:  mix phx.gen.secret
GUARDIAN_SECRET_KEY=

# Production-only (a release; not needed for `docker compose up` dev):
#   PHX_SERVER=true
#   PHX_HOST=your-domain.com
#   PORT=4000
#   SECRET_KEY_BASE=         # mix phx.gen.secret
#   DATABASE_URL=ecto://root:password@mysql/toia

# --- Database (MySQL) -------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_DATABASE=toia
DB_USERNAME=root
DB_PASSWORD=change-me

# --- Internal service routes (docker network service names) -----------------
Q_API_ROUTE=http://q_api:5000/generateNextQ
DM_ROUTE=http://toia-dm:5001/dialogue_manager

# --- AI: the single required external key ------------------------------------
# Used for question generation, embeddings, transcription (Whisper) and
# subtitle translation.
OPENAI_API_KEY=

# --- Email verification (optional) ------------------------------------------
# When false (default) new accounts are auto-confirmed and NO email provider
# is needed. Set to true only if you want signup email verification, and then
# provide a Resend API key + a verified "from" address.
REQUIRE_EMAIL_VERIFICATION=false
# RESEND_API_KEY=
# MAIL_FROM=noreply@your-domain.com
